# Umami Analytics Configuration
# Copy this file to .env and update values for production

# PostgreSQL Database
DB_NAME=umami
DB_USER=umami
DB_PASSWORD=umami_secure_pass_change_me

# Umami Application
# Full PostgreSQL connection string
DATABASE_URL=postgresql://umami:umami_secure_pass_change_me@postgres:5432/umami

# APP_SECRET: Random 32-character string used for hashing
# Generate with: openssl rand -base64 24
APP_SECRET=change_me_32_char_random_secret

# Tracker Script Name (to avoid ad-blocker detection)
# The tracking script will be served as this name instead of 'umami.js'
# Common alternatives: beacon, analytics, track, pixel, collect
TRACKER_SCRIPT_NAME=beacon

# Disable telemetry (Umami sends usage stats home by default)
# Set to 1 to disable sending data to Umami
DISABLE_TELEMETRY=1

# Optional: Log level
# Options: debug, info, warn, error
LOG_LEVEL=info

# Optional: Force SSL redirect
# Set to 1 if behind nginx with SSL termination
FORCE_SSL=0
